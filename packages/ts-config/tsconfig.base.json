{
	"$schema": "https://json.schemastore.org/tsconfig",
	// Shared base config for all TypeScript projects
	"compilerOptions": {
		// Base
		"esModuleInterop": true, // Allow default imports from CommonJS
		"jsx": "react-jsx", // Use the new JSX transform for React 17+
		"module": "preserve", // Keep the module syntax as-is (e.g. import/export) for bundlers to handle
		"noEmit": true, // Don't emit any output files. We're only using TypeScript for type-checking, Vite does the bundling.
		"moduleResolution": "Node",
		"skipLibCheck": true, // Skips checking the types of .d.ts files. This is important for performance.
		"target": "es2022", // Version of JS to output.
		"moduleDetection": "force", // Forces TypeScript to consider all files as modules. Helps avoiding 'cannot redeclare block-scoped variable' errors
		"isolatedModules": true, // Prevents a few TS features which are unsafe when treating modules as isolated files
		"verbatimModuleSyntax": true, // Force to use import type and export type
		"allowJs": true, // Allows you to import .js and .json files.
		"resolveJsonModule": true, // Allows you to import .js and .json files.

		// Strict Type checking options
		"strict": true, // Enable all strict type-checking options
		"allowUnreachableCode": false,
		"forceConsistentCasingInFileNames": true, // Prevent case-related import bugs
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,

		// Include the DOM types
		"lib": [ "es2022", "dom", "dom.iterable" ],
	},
	"exclude": [
		"${configDir}/node_modules"
	]
}
